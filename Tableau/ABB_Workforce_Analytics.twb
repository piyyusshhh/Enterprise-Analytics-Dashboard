            <column-instance column='[Calculation_1941067840405508]' derivation='None' name='[none:Calculation_1941067840405508:nk]' pivot='key' type='nominal' />
            <column-instance column='[Calculation_1941067836280835]' derivation='User' name='[usr:Calculation_1941067836280835:qk]' pivot='key' type='quantitative' />
          </datasource-dependencies>
          <manual-sort column='[federated.1nb01k50ef6trc17k7bwx15ytaon].[none:Calculation_1941067840405508:nk]' direction='ASC'>
            <dictionary>
              <bucket>&quot;&lt;3L&quot;</bucket>
              <bucket>&quot;3–5L&quot;</bucket>
              <bucket>&quot;5–7L&quot;</bucket>
              <bucket>&quot;7–9L&quot;</bucket>
              <bucket>&quot;9–11L&quot;</bucket>
              <bucket>&quot;11–13L&quot;</bucket>
              <bucket>&quot;13–16L&quot;</bucket>
              <bucket>&quot;16L+&quot;</bucket>
            </dictionary>
          </manual-sort>
          <aggregation value='true' />
        </view>
        <style>
