    <worksheet name='Salary Distribution'>
      <table>
        <view>
          <datasources>
            <datasource caption='Employee_Directory_Clean.csv (Multiple Connections)' name='federated.1nb01k50ef6trc17k7bwx15ytaon' />
          </datasources>
          <datasource-dependencies datasource='federated.1nb01k50ef6trc17k7bwx15ytaon'>
            <column caption='Average Salary' datatype='real' name='[Calculation_1941067836280835]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='ROUND(AVG([Salary_INR])/100000,2)' />
            </column>
            <column caption='Salary Band' datatype='string' name='[Calculation_1941067840405508]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [Salary_INR] &lt; 300000 THEN &quot;&lt;3L&quot;&#10;&#10;ELSEIF [Salary_INR] &lt; 500000 THEN &quot;3–5L&quot;&#10;&#10;ELSEIF [Salary_INR] &lt; 700000 THEN &quot;5–7L&quot;&#10;&#10;ELSEIF [Salary_INR] &lt; 900000 THEN &quot;7–9L&quot;&#10;&#10;ELSEIF [Salary_INR] &lt; 1100000 THEN &quot;9–11L&quot;&#10;&#10;ELSEIF [Salary_INR] &lt; 1300000 THEN &quot;11–13L&quot;&#10;&#10;ELSEIF [Salary_INR] &lt; 1600000 THEN &quot;13–16L&quot;&#10;&#10;ELSE &quot;16L+&quot;&#10;END' />
            </column>
            <column caption='Employee ID' datatype='string' name='[Employee_ID]' role='dimension' type='nominal' />
            <column caption='Salary INR' datatype='integer' name='[Salary_INR]' role='measure' type='quantitative' />
            <column-instance column='[Employee_ID]' derivation='CountD' name='[ctd:Employee_ID:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Calculation_1941067840405508]' derivation='None' name='[none:Calculation_1941067840405508:nk]' pivot='key' type='nominal' />
            <column-instance column='[Calculation_1941067836280835]' derivation='User' name='[usr:Calculation_1941067836280835:qk]' pivot='key' type='quantitative' />
          </datasource-dependencies>
          <manual-sort column='[federated.1nb01k50ef6trc17k7bwx15ytaon].[none:Calculation_1941067840405508:nk]' direction='ASC'>
            <dictionary>
              <bucket>&quot;&lt;3L&quot;</bucket>
              <bucket>&quot;3–5L&quot;</bucket>
              <bucket>&quot;5–7L&quot;</bucket>
              <bucket>&quot;7–9L&quot;</bucket>
              <bucket>&quot;9–11L&quot;</bucket>
              <bucket>&quot;11–13L&quot;</bucket>
              <bucket>&quot;13–16L&quot;</bucket>
              <bucket>&quot;16L+&quot;</bucket>
            </dictionary>
          </manual-sort>
          <aggregation value='true' />
        </view>
        <style>
          <style-rule element='cell'>
            <format attr='text-format' field='[federated.1nb01k50ef6trc17k7bwx15ytaon].[usr:Calculation_1941067836280835:qk]' value='c&quot;₹&quot;#,##0.00&quot;L&quot;;-&quot;₹&quot;#,##0.00&quot;L&quot;' />
          </style-rule>
        </style>
        <panes>
          <pane selection-relaxation-option='selection-relaxation-allow'>
            <view>
              <breakdown value='auto' />
            </view>
            <mark class='Bar' />
            <mark-sizing mark-sizing-setting='marks-scaling-off' />
            <encodings>
              <text column='[federated.1nb01k50ef6trc17k7bwx15ytaon].[usr:Calculation_1941067836280835:qk]' />
            </encodings>
            <style>
              <style-rule element='mark'>
                <format attr='mark-labels-cull' value='true' />
                <format attr='size' value='1.3953038454055786' />
                <format attr='mark-labels-show' value='false' />
                <format attr='mark-color' value='#4d98e6' />
