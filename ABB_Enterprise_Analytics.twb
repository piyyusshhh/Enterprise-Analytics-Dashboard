      <column caption='Highest Salary (Lakh)' datatype='real' name='[Calculation_1941067833819137]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='ROUND(MAX([Salary_INR]) / 100000, 2)' />
      </column>
      <column caption='Lowest Salary (Lakh)' datatype='real' name='[Calculation_1941067834843138]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='ROUND(MIN([Salary_INR]) / 100000, 2)' />
      </column>
      <column caption='Average Salary' datatype='real' name='[Calculation_1941067836280835]' role='measure' type='quantitative'>
