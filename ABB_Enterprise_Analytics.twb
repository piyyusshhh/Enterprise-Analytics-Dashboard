      <column caption='Salary Band' datatype='string' name='[Calculation_1941067840405508]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Salary_INR] &lt; 300000 THEN &quot;&lt;3L&quot;&#10;&#10;ELSEIF [Salary_INR] &lt; 500000 THEN &quot;3–5L&quot;&#10;&#10;ELSEIF [Salary_INR] &lt; 700000 THEN &quot;5–7L&quot;&#10;&#10;ELSEIF [Salary_INR] &lt; 900000 THEN &quot;7–9L&quot;&#10;&#10;ELSEIF [Salary_INR] &lt; 1100000 THEN &quot;9–11L&quot;&#10;&#10;ELSEIF [Salary_INR] &lt; 1300000 THEN &quot;11–13L&quot;&#10;&#10;ELSEIF [Salary_INR] &lt; 1600000 THEN &quot;13–16L&quot;&#10;&#10;ELSE &quot;16L+&quot;&#10;END' />
      </column>
      <column caption='Salary (Lakhs)' datatype='real' name='[Calculation_1941067845472261]' role='measure' type='quantitative'>
